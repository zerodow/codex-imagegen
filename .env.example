# Copy to `.env` (gitignored) and fill in your keys. Loaded automatically when you
# run a command from the project root. A real exported env var always takes
# precedence over a value here. Everything after the first `=` is the value —
# an inline `#` is NOT treated as a comment.
#
# Codex (default image provider) does NOT use this file — it reads the OAuth token
# from ~/.codex/auth.json (run `codex login`). Only MiniMax keys belong here.

# MiniMax vision (M3) — token-metered, so your MiniMax token plan covers it.
# Used by `imagegen-merge --vision minimax`.
MINIMAX_API_KEY=

# MiniMax image generation (Image-01) — per-image, pay-as-you-go (separate balance,
# NOT covered by the token plan). Used by `imagegen --provider minimax`.
MINIMAX_IMAGE_API_KEY=
